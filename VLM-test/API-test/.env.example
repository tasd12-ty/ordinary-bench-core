# VLM 测试配置 — 复制此文件为 .env 并填入你的密钥
# cp .env.example .env

# ── DashScope（阿里云百炼）──
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# ── OpenRouter ──
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# ── 阿里内部 API（llm-chat-api）──
ALI_INTERNAL_ACCESS_KEY=your-access-key
ALI_INTERNAL_QUOTA_ID=your-quota-id
ALI_INTERNAL_USER_ID=your-user-id

# ── Gemini（走阿里内部代理，与上面共用认证）──
GEMINI_VLM_ACCESS_KEY=your-access-key
GEMINI_VLM_QUOTA_ID=your-quota-id
GEMINI_VLM_USER_ID=your-user-id
